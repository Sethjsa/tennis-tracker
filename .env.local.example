# Supabase — from your project's API settings (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never exposed to the browser. Used by the ingest script
# and by server routes to write the shared tennis-data cache. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Which tours + years the ingest script pulls from Jeff Sackmann's open data.
# Comma-separated. Years are inclusive when given as a range "2018-2026".
INGEST_TOURS=atp,wta
INGEST_YEARS=2021-2026
